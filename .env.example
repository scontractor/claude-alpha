# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# --- LLM ---
# Set ANTHROPIC_API_KEY to use Claude API (required for Streamlit Cloud deployment).
# If not set, the app falls back to Ollama running locally.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Local Ollama (used when ANTHROPIC_API_KEY is not set)
OLLAMA_MODEL=llama3.2:1b
OLLAMA_BASE_URL=http://localhost:11434

# --- Storage ---
DATA_DIR=data
CHROMA_DIR=chroma_store
COLLECTION_NAME=knowledge_base

# --- Embeddings ---
EMBED_MODEL=BAAI/bge-large-en-v1.5

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
EMBED_BATCH_SIZE=32
TOP_K=5
